import 'package:flutter/material.dart';

class CustomDropdownButton<T> extends StatefulWidget {
  final T? value;
  final List<DropdownMenuItem<T>> items;
  final Function(T?)? onChanged;
  final InputDecoration decoration;
  final bool isExpanded;
  final Widget? hint;
  final TextStyle? style;
  final double? maxHeight;

  const CustomDropdownButton({
    super.key,
    required this.items,
    this.value,
    this.onChanged,
    this.decoration = const InputDecoration(),
    this.isExpanded = true,
    this.hint,
    this.style,
    this.maxHeight = 300.0,
  });

  @override
  State<CustomDropdownButton<T>> createState() => _CustomDropdownButtonState<T>();
}

class _CustomDropdownButtonState<T> extends State<CustomDropdownButton<T>> {
  final LayerLink _layerLink = LayerLink();
  final GlobalKey _buttonKey = GlobalKey();
  OverlayEntry? _overlayEntry;
  bool _isOpen = false;

  @override
  Widget build(BuildContext context) {
    return CompositedTransformTarget(
      link: _layerLink,
      child: Container(
        key: _buttonKey,
        child: InkWell(
          onTap: _toggleDropdown,
          child: InputDecorator(
            decoration: widget.decoration.copyWith(
              suffixIcon: Icon(
                _isOpen ? Icons.arrow_drop_up : Icons.arrow_drop_down,
                size: 24,
              ),
            ),
            child: widget.isExpanded
                ? SizedBox(
                    width: double.infinity,
                    child: _buildSelectedItem(),
                  )
                : _buildSelectedItem(),
          ),
        ),
      ),
    );
  }

  Widget _buildSelectedItem() {
    if (widget.value != null) {
      final selectedItem = widget.items.firstWhere(
        (item) => item.value == widget.value,
        orElse: () => widget.items.first,
      );
      return selectedItem.child;
    }
    return widget.hint ?? Text(
      '',
      style: widget.style?.copyWith(color: Colors.grey),
    );
  }

  void _toggleDropdown() {
    if (_isOpen) {
      _closeDropdown();
    } else {
      _openDropdown();
    }
  }

  void _openDropdown() {
    final RenderBox? renderBox = _buttonKey.currentContext?.findRenderObject() as RenderBox?;
    if (renderBox == null) return;

    final size = renderBox.size;
    final screenSize = MediaQuery.of(context).size;
    final viewInsets = MediaQuery.of(context).viewInsets;

    // Calcular posición global del botón
    final buttonGlobalPosition = renderBox.localToGlobal(Offset.zero);
    
    // Calcular espacio disponible debajo del botón
    final availableHeightBelow = screenSize.height - 
                                buttonGlobalPosition.dy - 
                                size.height - 
                                viewInsets.bottom - 
                                40; // Margen de seguridad
    
    // Calcular altura total necesaria para todos los items
    const double itemHeight = 56.0; // Altura estándar para cada item
    const double maxVisibleItems = 6; // Máximo items visibles sin scroll
    final totalItemsHeight = widget.items.length * itemHeight;
    final maxListHeight = maxVisibleItems * itemHeight;
    
    // Determinar altura final de la lista
    double dropdownHeight;
    
    if (totalItemsHeight <= maxListHeight) {
      // Si caben todos los items en el máximo sin scroll
      dropdownHeight = totalItemsHeight;
    } else {
      // Usar altura máxima con scroll
      dropdownHeight = maxListHeight;
    }
    
    // Ajustar si no cabe en pantalla
    if (dropdownHeight > availableHeightBelow && availableHeightBelow > 150) {
      dropdownHeight = availableHeightBelow - 10;
    } else if (availableHeightBelow <= 150) {
      // Si no hay espacio suficiente abajo, usar espacio mínimo
      dropdownHeight = 200.0.clamp(0.0, availableHeightBelow);
    }

    _overlayEntry = OverlayEntry(
      builder: (context) => Stack(
        children: [
          // Tap detector para cerrar dropdown
          Positioned.fill(
            child: GestureDetector(
              onTap: _closeDropdown,
              child: Container(
                color: Colors.transparent,
              ),
            ),
          ),
          // El dropdown real
          Positioned(
            left: buttonGlobalPosition.dx,
            top: buttonGlobalPosition.dy + size.height + 2.0,
            width: size.width,
            child: Material(
              elevation: 8.0,
              borderRadius: BorderRadius.circular(8.0),
              child: Container(
                constraints: BoxConstraints(
                  maxHeight: dropdownHeight,
                  minHeight: itemHeight.clamp(0.0, dropdownHeight),
                ),
                decoration: BoxDecoration(
                  color: Theme.of(context).cardColor,
                  borderRadius: BorderRadius.circular(8.0),
                  border: Border.all(color: Colors.grey.shade300),
                ),
                child: ClipRRect(
                  borderRadius: BorderRadius.circular(8.0),
                  child: Scrollbar(
                    thumbVisibility: widget.items.length > maxVisibleItems,
                    child: ListView.separated(
                      padding: EdgeInsets.zero,
                      shrinkWrap: true,
                      itemCount: widget.items.length,
                      separatorBuilder: (context, index) => Divider(
                        height: 1,
                        color: Colors.grey.shade200,
                      ),
                      itemBuilder: (context, index) {
                        final item = widget.items[index];
                        final isSelected = item.value == widget.value;
                        
                        return Container(
                          constraints: const BoxConstraints(minHeight: itemHeight),
                          decoration: BoxDecoration(
                            color: isSelected 
                                ? Theme.of(context).primaryColor.withOpacity(0.1) 
                                : null,
                          ),
                          child: InkWell(
                            onTap: () {
                              widget.onChanged?.call(item.value);
                              _closeDropdown();
                            },
                            child: Container(
                              padding: const EdgeInsets.symmetric(
                                horizontal: 16.0, 
                                vertical: 8.0,
                              ),
                              child: Align(
                                alignment: Alignment.centerLeft,
                                child: item.child,
                              ),
                            ),
                          ),
                        );
                      },
                    ),
                  ),
                ),
              ),
            ),
          ),
        ],
      ),
    );

    Overlay.of(context).insert(_overlayEntry!);
    setState(() => _isOpen = true);
  }

  void _closeDropdown() {
    _overlayEntry?.remove();
    _overlayEntry = null;
    setState(() => _isOpen = false);
  }

  @override
  void dispose() {
    _closeDropdown();
    super.dispose();
  }
}

// Dropdown personalizado específicamente para FormField
class CustomDropdownFormField<T> extends FormField<T> {
  CustomDropdownFormField({
    super.key,
    T? value,
    required List<DropdownMenuItem<T>> items,
    Function(T?)? onChanged,
    InputDecoration decoration = const InputDecoration(),
    String? Function(T?)? validator,
    bool isExpanded = true,
    Widget? hint,
    TextStyle? style,
    double? maxHeight = 300.0,
  }) : super(
          initialValue: value,
          validator: validator,
          builder: (FormFieldState<T> state) {
            return Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                CustomDropdownButton<T>(
                  value: state.value,
                  items: items,
                  onChanged: (T? newValue) {
                    state.didChange(newValue);
                    onChanged?.call(newValue);
                  },
                  decoration: decoration.copyWith(
                    errorText: state.hasError ? state.errorText : null,
                  ),
                  isExpanded: isExpanded,
                  hint: hint,
                  style: style,
                  maxHeight: maxHeight,
                ),
              ],
            );
          },
        );
}
